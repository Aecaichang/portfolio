---
import { getContent, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);

// Not all skill categories carry a targetRole in the locale JSON,
// so normalize to a uniform shape here.
const skills = t['skills'].map((category) => ({
  category: category.category,
  items: category.items,
  targetRole: 'targetRole' in category ? category.targetRole : undefined,
}));
---

<section id="skills" class="py-20 container mx-auto px-4 transition-colors duration-500">
  <div class="glass-card rounded-[2.5rem] p-8 md:p-12">
    <div class="reveal">
      <h2 id="skills-title" class="text-4xl font-bold text-center mb-10 bg-gradient-to-r from-blue-600 to-pink-500 dark:from-blue-400 dark:to-pink-400 bg-clip-text text-transparent">
        {t['titles.skills']}
      </h2>
    </div>
    <div id="skills-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        skills.map((category, index) => (
          <div class="reveal h-full" style={`transition-delay: ${index * 50}ms`}>
            <div
              id={`skills-card-${index}`}
              class={`h-full rounded-xl border bg-card text-card-foreground shadow hover:shadow-lg transition-[transform,box-shadow,background-color,border-color] duration-300 hover:-translate-y-1 dark:bg-slate-900/80 dark:border-slate-800 ${
                category.targetRole ? 'ring-1 ring-blue-200 dark:ring-blue-900/50' : ''
              }`}
            >
              <div id={`skills-header-${index}`} class="flex flex-col space-y-1.5 p-6 pb-3">
                {category.targetRole && (
                  <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold w-fit mx-auto mb-2 text-blue-700 dark:text-blue-300 border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-900/30">
                    {category.targetRole}
                  </span>
                )}
                <h3
                  id={`skills-category-${index}`}
                  class="font-semibold leading-none tracking-tight text-xl text-center text-slate-800 dark:text-slate-100 border-b pb-2 border-slate-100 dark:border-slate-800"
                >
                  {category.category}
                </h3>
              </div>
              <div id={`skills-content-${index}`} class="p-6 pt-0">
                <div class="flex flex-wrap gap-2 justify-center">
                  {category.items.map((item, i) => (
                    <span
                      id={`skill-badge-${index}-${i}`}
                      class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground font-semibold text-sm py-1 px-3 hover:bg-blue-100 dark:hover:bg-blue-900/40 hover:text-blue-700 dark:hover:text-blue-300 transition-colors cursor-default dark:bg-slate-800 dark:text-slate-300"
                    >
                      {item}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
