---
import { Image } from 'astro:assets';
import { getContent, type Locale } from '../lib/i18n';
import profileMain from '../assets/images/profile-new-1.jpg';
import profileHover from '../assets/images/profile-new-2.jpg';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const fullTitle = t['personalInfo.title'];

const socials = [
  { id: 'facebook', url: t['personalInfo.socials.facebook'], color: 'hover:text-blue-600 dark:hover:text-blue-400' },
  { id: 'linkedin', url: t['personalInfo.socials.linkedin'], color: 'hover:text-blue-700 dark:hover:text-blue-400' },
  { id: 'github', url: t['personalInfo.socials.github'], color: 'hover:text-slate-900 dark:hover:text-white' },
  { id: 'line', url: t['personalInfo.socials.line'], color: 'hover:text-green-500 dark:hover:text-green-400' },
] as const;

const socialIcons: Record<string, string> = {
  facebook:
    '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  linkedin:
    '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
  github:
    '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  line:
    '<path d="M12 2C6.48 2 2 5.88 2 10.67c0 4.29 3.55 7.88 8.35 8.56.33.07.77.22.88.5.1.26.07.66.03.92l-.14.86c-.04.26-.2 1.01.88.55 1.09-.46 5.87-3.46 8.01-5.93C21.66 14.4 22 12.6 22 10.67 22 5.88 17.52 2 12 2Z"/>',
};
---

<section
  id="home"
  class="min-h-screen flex items-center justify-center py-20 bg-gradient-to-br from-hero-from to-hero-to overflow-hidden transition-colors duration-500"
>
  <div class="container mx-auto glass-card rounded-[2.5rem] p-8 md:p-12">
    <div id="hero-container" class="flex flex-col-reverse md:flex-row items-center justify-between gap-12">
      <div id="hero-text-content" class="flex-1 text-center md:text-left space-y-6 animate-fade-in-left">
        <div id="hero-title-group">
          <h3 class="text-xl md:text-2xl font-medium text-slate-600 dark:text-slate-300 mb-2 text-balance animate-fade-in-up delay-100">
            {locale === 'th' ? 'สวัสดี, ผมชื่อ' : "Hello, I'm"}
          </h3>
          <h1 class="text-5xl md:text-7xl font-extrabold pb-2 bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400 bg-clip-text text-transparent text-balance animate-fade-in-up delay-200">
            {t['personalInfo.name']}
          </h1>
          <p class="text-base md:text-lg font-medium text-slate-500 dark:text-slate-400 mt-2 tracking-wide min-h-[1.75rem] animate-fade-in-up delay-300">
            <span class="sr-only">{fullTitle}</span>
            <span aria-hidden="true" id="typewriter" data-roles={fullTitle}>
              <span id="typewriter-text">{fullTitle}</span>
              <span id="typewriter-caret" class="hidden w-0.5 h-4 ml-0.5 align-middle bg-blue-500 animate-caret"></span>
            </span>
          </p>
        </div>

        <div id="hero-contact-info" class="mt-6 animate-fade-in-up delay-300">
          <div class="inline-flex w-full md:w-auto rounded-xl border border-slate-200/60 bg-white/60 dark:border-slate-800/60 dark:bg-slate-900/60 backdrop-blur-md shadow-sm hover:shadow-md transition-all duration-300 p-3">
            <div class="flex flex-wrap gap-2 items-center justify-center md:justify-start text-slate-700 dark:text-slate-300">
              <a href={`mailto:${t['personalInfo.email']}`} class="inline-flex items-center gap-2 h-9 px-3 rounded-md hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                <svg class="w-4 h-4 text-blue-500 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <span class="text-sm font-medium">{t['personalInfo.email']}</span>
              </a>
              <span class="hidden md:block w-px h-6 bg-slate-200 dark:bg-slate-700" role="separator"></span>
              <span class="inline-flex items-center h-9 px-3 rounded-md bg-secondary text-sm font-medium">
                <svg class="w-4 h-4 mr-1.5 text-blue-500 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                {t['personalInfo.location']}
              </span>
              <span
                class="inline-flex items-center gap-2 h-9 px-3 rounded-md border border-slate-200 dark:border-slate-700 text-sm font-medium"
                title={locale === 'th' ? 'อายุจริงในปัจจุบัน' : 'Current exact age'}
              >
                <svg class="w-4 h-4 text-blue-500 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-8a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8"/><path d="M4 16s.5-1 2-1 2.5 2 4 2 2.5-2 4-2 2.5 2 4 2 2-1 2-1"/><path d="M2 21h20"/><path d="M7 8v3"/><path d="M12 8v3"/><path d="M17 8v3"/><path d="M7 4h.01"/><path d="M12 4h.01"/><path d="M17 4h.01"/></svg>
                <span id="hero-age" class="tabular-nums" data-birthdate={t['personalInfo.birthDate']} data-locale={locale}></span>
              </span>
            </div>
          </div>
        </div>

        <div id="hero-social-links" class="flex gap-4 justify-center md:justify-start animate-scale-in delay-400">
          {
            socials.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.id}
                title={social.id.charAt(0).toUpperCase() + social.id.slice(1)}
                class={`inline-flex items-center justify-center w-10 h-10 rounded-full border border-slate-200 dark:border-slate-700 shadow-sm transition-[transform,box-shadow,color] duration-300 hover:shadow-md hover:-translate-y-1 ${social.color} text-slate-700 dark:text-slate-300`}
              >
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={socialIcons[social.id]} />
              </a>
            ))
          }
        </div>
      </div>

      <div id="hero-image-content" class="flex-1 flex justify-center md:justify-end animate-scale-in" style="perspective: 1000px">
        <div id="hero-image-wrapper" class="relative w-64 h-64 md:w-96 md:h-96 transition-transform duration-200 ease-out" style="transform-style: preserve-3d">
          <div class="absolute inset-0 bg-blue-600/10 rounded-full blur-3xl animate-blur-pulse"></div>

          <div class="relative w-full h-full rounded-full border-8 border-white shadow-2xl overflow-hidden bg-white group" style="transform: translateZ(50px)">
            <Image
              src={profileMain}
              alt={t['personalInfo.name']}
              width={768}
              height={768}
              class="w-full h-full object-cover"
              loading="eager"
              fetchpriority="high"
            />
            <Image
              src={profileHover}
              alt=""
              width={768}
              height={768}
              class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700 ease-in-out group-hover:opacity-100"
              loading="lazy"
            />
          </div>

          <div class="absolute -z-10 top-10 -right-10 w-20 h-20 bg-pink-400 rounded-full blur-xl opacity-30 animate-float-y" style="transform: translateZ(-20px)"></div>
          <div class="absolute -z-10 -bottom-5 -left-5 w-32 h-32 bg-blue-400 rounded-full blur-2xl opacity-30 animate-float-y delay-400" style="transform: translateZ(-40px)"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { calculateAge, type Locale } from '../lib/i18n';

  // Exact age, computed client-side so it never goes stale on a static build
  const ageEl = document.getElementById('hero-age');
  if (ageEl) {
    ageEl.textContent = calculateAge(ageEl.dataset.birthdate ?? '', ageEl.dataset.locale as Locale);
  }

  const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Typewriter for role titles
  const typewriter = document.getElementById('typewriter');
  const textEl = document.getElementById('typewriter-text');
  const caret = document.getElementById('typewriter-caret');
  if (typewriter && textEl && caret && !reducedMotion) {
    const roles = (typewriter.dataset.roles ?? '').split(' · ');
    const TYPING_MS = 80;
    const DELETING_MS = 40;
    const PAUSE_MS = 2000;
    caret.classList.remove('hidden');
    caret.classList.add('inline-block');

    let roleIndex = 0;
    let length = 0;
    let deleting = false;

    const tick = () => {
      const current = roles[roleIndex] ?? '';
      length += deleting ? -1 : 1;
      textEl.textContent = current.slice(0, length);

      let delay = deleting ? DELETING_MS : TYPING_MS;
      if (!deleting && length === current.length) {
        deleting = true;
        delay = PAUSE_MS;
      } else if (deleting && length === 0) {
        deleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
      }
      setTimeout(tick, delay);
    };
    textEl.textContent = '';
    length = 0;
    tick();
  }

  // 3D tilt on the profile image
  const imageContent = document.getElementById('hero-image-content');
  const wrapper = document.getElementById('hero-image-wrapper');
  if (imageContent && wrapper && !reducedMotion && matchMedia('(hover: hover)').matches) {
    imageContent.addEventListener('mousemove', (e) => {
      const rect = imageContent.getBoundingClientRect();
      const x = e.clientX - (rect.left + rect.width / 2);
      const y = e.clientY - (rect.top + rect.height / 2);
      const rotateY = Math.max(-10, Math.min(10, (x / 300) * 10));
      const rotateX = Math.max(-10, Math.min(10, (-y / 300) * 10));
      wrapper.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });
    imageContent.addEventListener('mouseleave', () => {
      wrapper.style.transform = 'rotateX(0deg) rotateY(0deg)';
    });
  }
</script>
