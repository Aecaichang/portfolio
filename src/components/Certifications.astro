---
import { getContent, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

interface CertificationItem {
  name: string;
  issuer: string;
  date?: string;
  credentialId?: string;
  skill?: string;
  link?: string;
}

const { locale } = Astro.props;
const t = getContent(locale);
const certifications = t['certifications'] as unknown as CertificationItem[];
---

<section id="certifications" class="py-20 container mx-auto px-4 transition-colors duration-500">
  <div class="glass-card rounded-[2.5rem] p-8 md:p-12">
    <div class="reveal">
      <h2
        id="certifications-title"
        class="text-4xl font-bold text-center mb-10 bg-gradient-to-r from-blue-600 to-pink-500 dark:from-blue-400 dark:to-pink-400 bg-clip-text text-transparent"
      >
        {t['titles.certifications']}
      </h2>
    </div>
    <div id="certifications-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {
        certifications.map((cert, index) => (
          <article
            id={`cert-card-${index}`}
            class="reveal rounded-lg border bg-card text-card-foreground shadow-sm flex flex-col h-full hover:shadow-lg transition-[box-shadow,background-color,border-color] duration-300 dark:bg-slate-900/80 dark:border-slate-800"
            style={`transition-delay: ${index * 100}ms`}
          >
            <header id={`cert-header-${index}`} class="flex flex-row gap-4 p-6 pb-4">
              <div
                id={`cert-issuer-icon-${index}`}
                class="w-12 h-12 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-xl font-bold text-slate-600 dark:text-slate-300 shrink-0"
                aria-hidden="true"
              >
                {cert.issuer.charAt(0)}
              </div>
              <div class="flex-1 min-w-0">
                <h3
                  id={`cert-name-${index}`}
                  class="text-lg font-semibold leading-tight mb-1 line-clamp-2 text-balance dark:text-slate-100"
                  title={cert.name}
                >
                  {cert.name}
                </h3>
                <p
                  id={`cert-issuer-name-${index}`}
                  class="text-sm font-medium text-slate-600 dark:text-slate-300 text-balance"
                >
                  {cert.issuer}
                </p>
              </div>
            </header>
            <div id={`cert-content-${index}`} class="flex-1 flex flex-col p-6 pt-0">
              <div class="space-y-2 mb-4 flex-1">
                {cert.date && (
                  <p id={`cert-date-${index}`} class="text-sm text-slate-600 dark:text-slate-300 tabular-nums">
                    {cert.date}
                  </p>
                )}
                {cert.credentialId && (
                  <p
                    id={`cert-cred-id-${index}`}
                    class="text-xs text-slate-600 dark:text-slate-300 font-mono tabular-nums"
                  >
                    ID: {cert.credentialId}
                  </p>
                )}
                {cert.skill && (
                  <span
                    id={`cert-skill-${index}`}
                    class="inline-flex items-center rounded-full border px-2.5 py-0.5 mt-2 text-xs font-normal border-blue-200 dark:border-blue-800 text-blue-700 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/30"
                  >
                    💎 {cert.skill}
                  </span>
                )}
              </div>

              {cert.link && cert.link !== '#' && (
                <a
                  id={`btn-cert-show-${index}`}
                  href={cert.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3 text-sm font-medium transition-colors w-full mt-auto dark:border-slate-700 dark:hover:bg-slate-800 dark:text-slate-300"
                >
                  {t['titles.viewProject'] || 'View Credential'}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3 h-3 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M15 3h6v6" />
                    <path d="M10 14 21 3" />
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  </svg>
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
