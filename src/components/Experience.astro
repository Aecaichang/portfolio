---
import { getContent, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

interface ExperienceRole {
  title: string;
  period: string;
  description?: string | string[];
  achievements?: string[];
  leadership?: string[];
}

interface ExperienceItem {
  company: string;
  type: string;
  location?: string;
  roles: ExperienceRole[];
}

const { locale } = Astro.props;
const t = getContent(locale);
const experience = t['experience'] as unknown as ExperienceItem[];

/** Normalize a role description into a list of bullet items, or a single paragraph. */
function toBullets(description: string | string[]): string[] | null {
  if (Array.isArray(description)) return description;
  if (description.includes('\n')) {
    return description.split('\n').map((item) => item.replace(/^•\s*/, ''));
  }
  return null;
}
---

<section id="experience" class="py-20 bg-secondary/50 transition-colors duration-500">
  <div id="experience-container" class="container mx-auto px-4 max-w-4xl">
    <div class="glass-card rounded-[2.5rem] p-8 md:p-12">
      <div class="reveal">
        <h2
          id="experience-title"
          class="text-4xl font-bold text-center mb-12 bg-gradient-to-r from-blue-600 to-pink-500 dark:from-blue-400 dark:to-pink-400 bg-clip-text text-transparent"
        >
          {t['titles.experience']}
        </h2>
      </div>

      <div id="experience-list" class="space-y-8">
        {
          experience.map((job, index) => (
            <article
              id={`experience-card-${index}`}
              class="reveal rounded-lg border bg-card text-card-foreground shadow-sm border-l-4 border-l-blue-600 dark:border-slate-800 dark:border-l-blue-500 hover:shadow-lg transition-[box-shadow,background-color,border-color] duration-300 dark:bg-slate-900/80"
              style={`transition-delay: ${index * 100}ms`}
            >
              <header id={`experience-header-${index}`} class="flex flex-col space-y-1.5 p-6 pb-2">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 mb-2">
                  <h3
                    id={`experience-company-${index}`}
                    class="text-2xl font-bold leading-none tracking-tight text-slate-800 dark:text-slate-100 text-balance"
                  >
                    {job.company}
                  </h3>
                  <span
                    id={`experience-type-${index}`}
                    class="inline-flex items-center rounded-full border border-transparent bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold w-fit dark:bg-slate-800 dark:text-slate-300"
                  >
                    {job.type}
                  </span>
                </div>
                {job.location && (
                  <p
                    id={`experience-location-${index}`}
                    class="text-sm text-slate-600 dark:text-slate-300 flex items-center gap-1"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                      <circle cx="12" cy="10" r="3" />
                    </svg>
                    {job.location}
                  </p>
                )}
              </header>
              <div id={`experience-content-${index}`} class="p-6 pt-0">
                <div class="relative pl-6 sm:pl-8 border-l-2 border-slate-200 dark:border-slate-700 ml-2 space-y-8 py-2">
                  {job.roles.map((role, rIndex) => {
                    const bullets = role.description ? toBullets(role.description) : null;
                    return (
                      <div class="relative" id={`experience-job-${index}-role-${rIndex}`}>
                        <div class="absolute -left-[33px] sm:-left-[41px] top-1.5 w-4 h-4 rounded-full bg-white dark:bg-slate-900 border-4 border-blue-600 dark:border-blue-500" />

                        <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-2">
                          <h4
                            id={`experience-role-title-${index}-${rIndex}`}
                            class="text-lg font-semibold text-slate-800 dark:text-slate-200 text-balance"
                          >
                            {role.title}
                          </h4>
                          <span
                            id={`experience-role-period-${index}-${rIndex}`}
                            class="text-sm text-slate-600 dark:text-slate-300 font-medium tabular-nums"
                          >
                            {role.period}
                          </span>
                        </div>

                        {role.description && (
                          <div
                            id={`experience-role-desc-${index}-${rIndex}`}
                            class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed"
                          >
                            {bullets ? (
                              <ul class="list-disc pl-5 space-y-1">
                                {bullets.map((item) => (
                                  <li>{item}</li>
                                ))}
                              </ul>
                            ) : (
                              <p>{role.description}</p>
                            )}
                          </div>
                        )}

                        {role.achievements && role.achievements.length > 0 && (
                          <div class="mt-4">
                            <p class="text-sm font-semibold text-blue-700 dark:text-blue-300 mb-2">
                              {t['titles.keyAchievements'] || 'Key Achievements'}
                            </p>
                            <ul class="list-disc pl-5 space-y-1 text-slate-700 dark:text-slate-300 text-sm">
                              {role.achievements.map((item) => (
                                <li>{item}</li>
                              ))}
                            </ul>
                          </div>
                        )}

                        {role.leadership && role.leadership.length > 0 && (
                          <div class="mt-4">
                            <p class="text-sm font-semibold text-pink-700 dark:text-pink-300 mb-2">
                              {t['titles.softLeadership'] || 'Soft Skills & Leadership'}
                            </p>
                            <ul class="list-disc pl-5 space-y-1 text-slate-700 dark:text-slate-300 text-sm">
                              {role.leadership.map((item) => (
                                <li>{item}</li>
                              ))}
                            </ul>
                          </div>
                        )}
                      </div>
                    );
                  })}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
