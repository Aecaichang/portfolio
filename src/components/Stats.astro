---
import { getContent, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);

interface Stat {
  icon: string;
  value: string;
  label: string;
  color: string;
}

// Lucide outline icon paths (briefcase, code, award, badge-check)
const stats: Stat[] = [
  {
    icon: '<path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/>',
    value: '7+',
    label: t['stats.experience'],
    color: 'from-blue-500 to-cyan-500',
  },
  {
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
    value: '10+',
    label: t['stats.projects'],
    color: 'from-purple-500 to-pink-500',
  },
  {
    icon: '<path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/><circle cx="12" cy="8" r="6"/>',
    value: '20+',
    label: t['stats.skills'],
    color: 'from-orange-500 to-red-500',
  },
  {
    icon: '<path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/>',
    value: '3',
    label: t['stats.certifications'],
    color: 'from-green-500 to-emerald-500',
  },
];
---

<section id="stats" class="py-20 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary/5 to-transparent"></div>

  <div class="container mx-auto relative z-10">
    <div class="reveal text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black mb-4 bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400 bg-clip-text text-transparent">
        {t['stats.title']}
      </h2>
      <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
        {t['stats.subtitle']}
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {
        stats.map((stat, index) => (
          <div class="reveal group" style={`transition-delay: ${index * 100}ms`}>
            <div class="glass-card glass-card-hover rounded-[2.5rem] p-8 text-center h-full flex flex-col items-center justify-center">
              <div class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${stat.color} p-0.5 mb-6 group-hover:scale-110 transition-transform duration-300`}>
                <div class="w-full h-full rounded-2xl bg-background dark:bg-slate-900 flex items-center justify-center">
                  <div class={`bg-gradient-to-br ${stat.color} bg-clip-text text-transparent`}>
                    <svg
                      class="w-8 h-8"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      set:html={stat.icon}
                    />
                  </div>
                </div>
              </div>

              <div
                class={`stat-count-up text-5xl md:text-6xl font-black mb-3 bg-gradient-to-br ${stat.color} bg-clip-text text-transparent tabular-nums`}
                data-value={stat.value}
              >
                {stat.value}
              </div>

              <p class="text-sm md:text-base font-semibold text-muted-foreground uppercase tracking-widest">
                {stat.label}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const COUNT_UP_DURATION_MS = 1000;
  const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const counters = document.querySelectorAll<HTMLElement>('#stats .stat-count-up');

  const animateCount = (el: HTMLElement): void => {
    const value = el.dataset.value ?? '';
    const target = parseInt(value.replace(/\D/g, ''), 10) || 0;
    const suffix = value.replace(/\d/g, '');

    if (reducedMotion) {
      el.textContent = `${target}${suffix}`;
      return;
    }

    const start = performance.now();
    const frame = (now: number): void => {
      const progress = Math.min((now - start) / COUNT_UP_DURATION_MS, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = `${Math.round(eased * target)}${suffix}`;
      if (progress < 1) requestAnimationFrame(frame);
    };
    el.textContent = `0${suffix}`;
    requestAnimationFrame(frame);
  };

  const observer = new IntersectionObserver(
    (entries, obs) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          animateCount(entry.target as HTMLElement);
          obs.unobserve(entry.target);
        }
      }
    },
    { rootMargin: '-100px' },
  );

  counters.forEach((el) => observer.observe(el));
</script>
