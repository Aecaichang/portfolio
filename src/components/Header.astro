---
import { getContent, localePath, alternatePath, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const base = localePath(locale);
const altHref = alternatePath(locale, Astro.url.pathname);

const NAV_ITEMS = ['home', 'aboutMe', 'experience', 'education', 'skills', 'portfolio'] as const;
---

<header
  id="main-header"
  class="fixed top-0 w-full z-50 transition-all duration-300 bg-transparent py-5 data-[scrolled]:bg-white/80 data-[scrolled]:dark:bg-slate-900/80 data-[scrolled]:backdrop-blur-md data-[scrolled]:shadow-md data-[scrolled]:py-3"
>
  <div class="container mx-auto px-4 flex justify-between items-center">
    <a
      href="#home"
      class="text-2xl font-bold text-slate-900 dark:text-slate-100 hover:opacity-80 transition-opacity"
    >
      Portfolio.
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Main navigation" class="hidden md:block">
      <ul class="flex items-center space-x-6">
        {
          NAV_ITEMS.map((item) => (
            <li>
              <a
                href={`#${item}`}
                data-nav={item}
                class="inline-flex items-center rounded-md px-2 py-1.5 text-sm font-semibold transition-colors text-slate-900 dark:text-slate-300 hover:bg-slate-100 hover:text-blue-700 dark:hover:bg-slate-800 dark:hover:text-blue-400 data-[active]:text-blue-700 data-[active]:dark:text-blue-400 data-[active]:bg-blue-50 data-[active]:dark:bg-blue-900/20"
              >
                {t[`nav.${item}`]}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <!-- CV button — desktop only -->
      <a
        href={`${base}/cv`}
        target="_blank"
        class="hidden sm:inline-flex items-center gap-2 mr-2 h-9 rounded-md border border-slate-200 dark:border-slate-700 px-3 text-sm font-medium text-slate-800 dark:text-slate-200 hover:bg-blue-50 hover:text-blue-700 dark:hover:bg-slate-800 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
        {t['nav.downloadCv']}
      </a>

      <!-- Theme toggle -->
      <button
        id="btn-theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full text-slate-800 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
      >
        <svg class="w-5 h-5 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        <svg class="w-5 h-5 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
      </button>

      <!-- Language toggle -->
      <a
        href={altHref}
        aria-label={locale === 'en' ? 'เปลี่ยนภาษาเป็นไทย' : 'Switch language to English'}
        class="inline-flex items-center h-10 px-3 rounded-full font-bold text-sm text-slate-800 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
      >
        {locale === 'en' ? 'ไทย' : 'EN'}
      </a>

      <!-- Mobile menu -->
      <button
        id="btn-mobile-menu"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full text-slate-800 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    aria-label="Mobile navigation"
    class="hidden md:!hidden absolute top-full right-4 w-64 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 shadow-xl p-3 flex-col gap-1"
  >
    {
      NAV_ITEMS.map((item) => (
        <a
          href={`#${item}`}
          class="px-4 py-3 rounded-lg text-base font-semibold text-slate-800 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-blue-700 dark:hover:text-blue-400 transition-colors"
        >
          {t[`nav.${item}`]}
        </a>
      ))
    }
    <a
      href={`${base}/cv`}
      target="_blank"
      class="mt-2 px-4 py-3 rounded-lg text-base font-semibold text-center border border-slate-200 dark:border-slate-700 text-slate-800 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
    >
      {t['nav.downloadCv']}
    </a>
  </nav>
</header>

<script>
  const header = document.getElementById('main-header')!;
  const themeBtn = document.getElementById('btn-theme-toggle')!;
  const menuBtn = document.getElementById('btn-mobile-menu')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  // Shrink header on scroll
  const onScroll = () => {
    header.toggleAttribute('data-scrolled', window.scrollY > 50);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Theme toggle
  themeBtn.addEventListener('click', () => {
    const dark = !document.documentElement.classList.contains('dark');
    document.documentElement.classList.toggle('dark', dark);
    document.documentElement.style.colorScheme = dark ? 'dark' : 'light';
    localStorage.setItem('theme', dark ? 'dark' : 'light');
  });

  // Mobile menu
  const closeMenu = () => {
    mobileMenu.classList.add('hidden');
    mobileMenu.classList.remove('flex');
    menuBtn.setAttribute('aria-expanded', 'false');
  };
  menuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    if (isOpen) return closeMenu();
    mobileMenu.classList.remove('hidden');
    mobileMenu.classList.add('flex');
    menuBtn.setAttribute('aria-expanded', 'true');
  });
  mobileMenu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

  // Active section highlight — pick the entry nearest the top of the viewport
  const links = [...document.querySelectorAll<HTMLAnchorElement>('[data-nav]')];
  const setActive = (id: string) => {
    for (const link of links) link.toggleAttribute('data-active', link.dataset.nav === id);
  };
  const visible = new Map<string, number>();
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) visible.set(entry.target.id, entry.boundingClientRect.top);
        else visible.delete(entry.target.id);
      }
      if (visible.size > 0) {
        const topmost = [...visible.entries()].sort((a, b) => a[1] - b[1])[0]![0];
        setActive(topmost);
      }
    },
    { rootMargin: '-20% 0px -75% 0px', threshold: 0 },
  );
  for (const link of links) {
    const section = document.getElementById(link.dataset.nav!);
    if (section) observer.observe(section);
  }
</script>
