---
import { getContent, alternatePath, localePath, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);

type Experience = (typeof t)['experience'][number];
type Role = Experience['roles'][number];

const getAchievements = (role: Role): readonly string[] =>
  'achievements' in role && Array.isArray(role.achievements) ? role.achievements : [];

const companyPeriod = (job: Experience): string => {
  const period = job.roles[0]?.period ?? '';
  return period.split('·')[0]?.trim() ?? '';
};

const homeHref = localePath(locale) || '/';
const switchHref = alternatePath(locale, Astro.url.pathname);
const recentProject = t['portfolio'][0];

const keyAttributes = [
  { title: 'Problem Solver', desc: 'Turning complex requirements into actionable technical plans.' },
  { title: 'Detail Oriented', desc: 'QA background ensures high attention to edge cases and quality.' },
  { title: 'Adaptive Learner', desc: 'Quickly mastering new stacks (Supabase, Deno, AI Agents).' },
] as const;

const sectionTitleClass =
  'text-lg font-bold uppercase tracking-widest border-l-4 border-blue-600 pl-3 mb-4 text-slate-800';
---

<div class="min-h-screen bg-slate-100 dark:bg-slate-900 px-6 py-4 md:px-12 md:py-8 flex flex-col items-center">
  <div class="w-full max-w-[210mm] mb-4 flex justify-between items-center print:hidden">
    <a
      href={homeHref}
      class="inline-flex items-center gap-2 h-8 px-3 rounded-md border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm font-medium text-slate-700 dark:text-slate-200 shadow-sm hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Back to Home
    </a>
    <div class="flex gap-2">
      <a
        href={switchHref}
        class="inline-flex items-center gap-2 h-8 px-3 rounded-md border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm font-medium text-slate-700 dark:text-slate-200 shadow-sm hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        {locale === 'en' ? 'Switch to Thai' : 'Switch to English'}
      </a>
      <button
        id="cv-print-button"
        type="button"
        class="inline-flex items-center gap-2 h-8 px-3 rounded-md bg-blue-600 text-sm font-medium text-white shadow-sm hover:bg-blue-700 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 9V3a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v6"/><rect x="6" y="14" width="12" height="8" rx="1"/></svg>
        Print / Save as PDF
      </button>
    </div>
  </div>

  <div
    class="w-full max-w-[210mm] min-h-[297mm] bg-white text-slate-800 shadow-xl print:shadow-none p-[10mm] md:p-[15mm] mx-auto overflow-hidden print:w-full print:max-w-none print:m-0 print:p-[10mm]"
  >
    <!-- Header -->
    <header class="flex justify-between items-start mb-6 border-b-2 border-slate-800 pb-6">
      <div>
        <h1 class="text-4xl font-bold uppercase tracking-tight text-slate-900 mb-2">
          {t['personalInfo.name']}
        </h1>
        <h2 class="text-xl text-blue-700 font-semibold tracking-wide uppercase">
          {t['personalInfo.title']}
        </h2>
        <p class="mt-3 text-sm text-slate-600 max-w-lg leading-relaxed">
          {t['aboutMe.paragraph1']} {t['aboutMe.paragraph2']}
        </p>
      </div>
      <div class="text-right space-y-1.5 text-xs md:text-sm">
        <div class="flex items-center justify-end gap-2 text-slate-600">
          <span>{t['personalInfo.phone']}</span>
          <svg class="w-3.5 h-3.5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div class="flex items-center justify-end gap-2 text-slate-600">
          <a href={`mailto:${t['personalInfo.email']}`} class="hover:text-blue-600 underline-offset-2 hover:underline">
            {t['personalInfo.email']}
          </a>
          <svg class="w-3.5 h-3.5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </div>
        <div class="flex items-center justify-end gap-2 text-slate-600">
          <span>{t['personalInfo.location']}</span>
          <svg class="w-3.5 h-3.5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div class="flex items-center justify-end gap-2 text-slate-600">
          <a href={t['personalInfo.socials.linkedin']} target="_blank" rel="noreferrer" class="hover:text-blue-600 underline-offset-2 hover:underline">
            LinkedIn
          </a>
          <svg class="w-3.5 h-3.5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </div>
        <div class="flex items-center justify-end gap-2 text-slate-600">
          <a href={t['personalInfo.socials.github']} target="_blank" rel="noreferrer" class="hover:text-blue-600 underline-offset-2 hover:underline">
            GitHub
          </a>
          <svg class="w-3.5 h-3.5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </div>
      </div>
    </header>

    <!-- Content Grid -->
    <div class="grid grid-cols-12 gap-8">
      <!-- Left Column (Main Experience) -->
      <div class="col-span-8 space-y-8">
        <!-- Experience -->
        <section>
          <h3 class={sectionTitleClass}>{t['titles.experience']}</h3>

          <div class="space-y-6">
            {
              t['experience'].map((job) => (
                <div class="relative pl-4 border-l-2 border-slate-200">
                  <div class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full bg-slate-100 border-2 border-blue-600" />
                  <div class="flex justify-between items-baseline mb-1">
                    <h4 class="font-bold text-slate-900 text-base">{job.company}</h4>
                    <span class="text-xs text-slate-500 font-medium whitespace-nowrap">{companyPeriod(job)}</span>
                  </div>

                  {job.roles.map((role, rIndex) => (
                    <div class={rIndex > 0 ? 'mt-4' : ''}>
                      <div class="flex justify-between items-center mb-1">
                        <h5 class="font-semibold text-blue-700">{role.title}</h5>
                      </div>
                      <ul class="list-disc list-outside ml-4 space-y-1 text-xs text-slate-700 leading-relaxed marker:text-slate-400">
                        {role.description.map((desc) => (
                          <li>{desc}</li>
                        ))}
                        {getAchievements(role).map((ach) => (
                          <li class="italic text-slate-600">Achievement: {ach}</li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              ))
            }
          </div>
        </section>

        <!-- Education -->
        <section>
          <h3 class={sectionTitleClass}>{t['titles.education']}</h3>
          <div class="grid grid-cols-1 gap-4">
            {
              t['education'].map((edu) => (
                <div>
                  <div class="flex justify-between items-baseline">
                    <h4 class="font-bold text-slate-900">{edu.university}</h4>
                    {edu.year && <span class="text-xs text-slate-500">{edu.year}</span>}
                  </div>
                  <p class="text-sm text-blue-700">{edu.degree}</p>
                  {edu.honors && <p class="text-xs text-slate-500 mt-0.5">{edu.honors}</p>}
                </div>
              ))
            }
          </div>
        </section>

        <!-- Recent Project -->
        {
          recentProject && (
            <section class="break-inside-avoid">
              <h3 class={sectionTitleClass}>Recent Project</h3>
              <div class="bg-slate-50 p-4 rounded-lg border border-slate-100">
                <h4 class="font-bold text-slate-900">{recentProject.title}</h4>
                <p class="text-xs text-slate-600 mt-2 leading-relaxed mb-3">{recentProject.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {recentProject.techStack.slice(0, 8).map((tech) => (
                    <span class="inline-flex items-center rounded-full text-[10px] h-5 px-1.5 bg-white border border-slate-200 text-slate-600 font-normal">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </section>
          )
        }
      </div>

      <!-- Right Column (Skills & Info) -->
      <div class="col-span-4 space-y-8">
        <!-- Skills -->
        <section>
          <h3 class={sectionTitleClass}>Skills</h3>

          <div class="space-y-5">
            {
              t['skills'].map((skillGroup) => (
                <div>
                  <h5 class="font-semibold text-xs text-slate-400 uppercase tracking-wider mb-2">{skillGroup.category}</h5>
                  <div class="flex flex-wrap gap-1.5">
                    {skillGroup.items.map((item) => (
                      <span class="inline-block px-2 py-1 bg-slate-100 text-slate-700 text-xs rounded border border-slate-200 font-medium">
                        {item}
                      </span>
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </section>

        <!-- Certifications -->
        <section>
          <h3 class={sectionTitleClass}>Certifications</h3>
          <ul class="space-y-3">
            {
              t['certifications'].map((cert) => (
                <li class="text-xs">
                  <p class="font-semibold text-slate-900">{cert.name}</p>
                  <p class="text-slate-500">
                    {cert.issuer} • {cert.date}
                  </p>
                </li>
              ))
            }
          </ul>
        </section>

        <!-- Key Attributes -->
        <section>
          <h3 class={sectionTitleClass}>Key Attributes</h3>
          <div class="space-y-2">
            {
              keyAttributes.map((attr) => (
                <div class="text-xs text-slate-600">
                  <strong class="text-slate-900 block font-semibold mb-0.5">{attr.title}</strong>
                  {attr.desc}
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-12 pt-6 border-t border-slate-200 text-center text-[10px] text-slate-400 flex justify-between">
      <span>References available upon request</span>
      <span>Generated dynamically from Portfolio Website</span>
    </div>
  </div>
</div>

<script>
  document.getElementById('cv-print-button')?.addEventListener('click', () => {
    window.print();
  });
</script>
