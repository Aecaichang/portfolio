---
import Base from '../layouts/Base.astro';
import CVContent from '../components/CVContent.astro';
import { getContent, type Locale } from '../lib/i18n';

const locale: Locale = 'th';
const t = getContent(locale);
---

<Base
  locale={locale}
  title={`CV | ${t['personalInfo.name']}`}
  description={`ประวัติย่อ (CV) ของ ${t['personalInfo.name']} — ${t['personalInfo.title']} ประสบการณ์ทำงาน การศึกษา ทักษะ และใบรับรอง พร้อมดาวน์โหลดเป็น PDF`}
>
  <CVContent locale={locale} />
</Base>
